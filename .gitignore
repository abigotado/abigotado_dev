# ── Flutter / Dart / Pub ────────────────────────────────────────────
.dart_tool/
.flutter-plugins
.flutter-plugins-dependencies
.pub-cache/
.pub/
build/
**/doc/api/
*.dart.js
*.info.json
*.js_
*.js.deps
*.js.map

# Coverage
coverage/
*.lcov

# ── Generated code (regenerated by build_runner; keep out of VCS) ────
# If a future decision is to commit generated files, scope this narrowly.
*.g.dart
*.freezed.dart
*.gr.dart
*.config.dart
*.mocks.dart

# ── Localization generated output (arb is source; .dart output is gen)
lib/**/l10n/gen/

# ── Golden test failures (never commit failure artifacts) ───────────
**/failures/
**/*.failure.png

# ── Secrets / credentials (a static site has none — belt & braces) ──
.env
.env.*
!.env.example
*.pem
*.key
*.p12
*.keystore
*.jks
secrets/
**/service-account*.json
firebase-credentials*.json

# ── IDE / editor ────────────────────────────────────────────────────
.idea/
*.iml
*.ipr
*.iws
.vscode/
*.code-workspace

# ── OS junk ─────────────────────────────────────────────────────────
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db
desktop.ini

# ── Logs / temp / local scratch (not for a public showcase) ─────────
*.log
*.swp
*.tmp
.history/
scratch/
*.local.md
TODO.local.md

# ── FVM (commit .fvmrc to pin the SDK; ignore the symlinked SDK) ────
.fvm/flutter_sdk
